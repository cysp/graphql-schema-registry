{
  "name": "graphql-schema-registry",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "node --run format:check && node --run lint && node --run typecheck && node --run test",
    "dev": "node --env-file-if-exists=.env --watch src/index.ts",
    "drizzle:schema:generate": "drizzle-kit export --config ./drizzle.config.ts > db/schema.sql",
    "fastify:openapi:generate": "node tools/generate-fastify-openapi.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --type-aware --report-unused-disable-directives .",
    "lint:fix": "oxlint --type-aware --fix .",
    "start": "node src/index.ts",
    "test": "node --env-file-if-exists=.env --env-file-if-exists=.env.test --test --enable-source-maps",
    "test:integration": "node --env-file-if-exists=.env --env-file-if-exists=.env.test --test --enable-source-maps $(find src -name '*.integration.test.ts' -print | sort)",
    "test:integration:coverage": "node --env-file-if-exists=.env --env-file-if-exists=.env.test --test --enable-source-maps --experimental-test-coverage --test-coverage-exclude=**/*.fixture.ts --test-coverage-exclude=**/*.test.ts --test-coverage-exclude=**/*.test-support.ts --test-coverage-exclude=src/test-support/** --test-coverage-exclude=tools/** --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=lcov.integration.info $(find src -name '*.integration.test.ts' -print | sort)",
    "test:unit": "node --env-file-if-exists=.env --env-file-if-exists=.env.test --test --enable-source-maps $(find src tools -name '*.test.ts' ! -name '*.integration.test.ts' -print | sort)",
    "test:unit:coverage": "node --env-file-if-exists=.env --env-file-if-exists=.env.test --test --enable-source-maps --experimental-test-coverage --test-coverage-exclude=**/*.fixture.ts --test-coverage-exclude=**/*.test.ts --test-coverage-exclude=**/*.test-support.ts --test-coverage-exclude=src/test-support/** --test-coverage-exclude=tools/** --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=lcov.unit.info $(find src tools -name '*.test.ts' ! -name '*.integration.test.ts' -print | sort)",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@apollo/composition": "2.13.3",
    "@fastify/jwt": "10.0.0",
    "@fastify/sensible": "6.0.4",
    "drizzle-orm": "1.0.0-beta.20",
    "fastify": "5.8.4",
    "fastify-plugin": "5.1.0",
    "graphql": "16.13.2",
    "postgres": "3.4.9",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@apidevtools/json-schema-ref-parser": "15.3.5",
    "@fastify/swagger": "9.7.0",
    "@fastify/type-provider-json-schema-to-ts": "5.0.0",
    "@tsconfig/node24": "24.0.4",
    "@tsconfig/recommended": "1.0.13",
    "@tsconfig/strictest": "2.0.8",
    "@types/json-schema": "7.0.15",
    "@types/node": "24.12.2",
    "drizzle-kit": "1.0.0-beta.20",
    "json-schema-to-ts": "3.1.1",
    "oxfmt": "0.45.0",
    "oxlint": "1.58.0",
    "oxlint-tsgolint": "0.18.1",
    "typescript": "6.0.2",
    "yaml": "2.8.3"
  },
  "engines": {
    "node": "24"
  },
  "packageManager": "pnpm@10.33.0"
}
